{
  "version": 2,
  "buildCommand": "npm run build:all",
  "outputDirectory": "ui",
  "rewrites": [
    { "source": "/api/createFleet",           "destination": "/api/createFleet.js" },
    { "source": "/api/updateFleet",           "destination": "/api/updateFleet.js" },
    { "source": "/api/deployFleet",           "destination": "/api/deployFleet.js" },
    { "source": "/api/safetyCheck",           "destination": "/api/safetyCheck.js" },
    { "source": "/api/deployment/status",     "destination": "/api/deployment/status.js" },
    { "source": "/api/deployment/list",       "destination": "/api/deployment/list.js" },
    { "source": "/api/deployment/preflight",  "destination": "/api/deployment/preflight.js" },
    { "source": "/api/deployment/rollback",   "destination": "/api/deployment/rollback.js" },
    { "source": "/api/device/checkin",        "destination": "/api/device/checkin.js" },
    { "source": "/api/device/heartbeat",      "destination": "/api/device/heartbeat.js" },
    { "source": "/api/driver/sync",           "destination": "/api/driver/sync.js" },
    { "source": "/api/hazard/report",         "destination": "/api/hazard/report.js" },
    { "source": "/api/hazard/confirm",        "destination": "/api/hazard/confirm.js" },
    { "source": "/api/hazard/dispute",        "destination": "/api/hazard/dispute.js" },
    { "source": "/api/tacho/activity",        "destination": "/api/tacho/activity.js" },
    { "source": "/api/tacho/session",         "destination": "/api/tacho/session.js" },
    { "source": "/api/obs/query",             "destination": "/api/obs/query.js" },
    { "source": "/api/obs/export",            "destination": "/api/obs/export.js" },
    { "source": "/api/nav/event",             "destination": "/api/nav/event.js" },
    { "source": "/controller/(.*)",           "destination": "/controller-dist/$1" },
    { "source": "/fleet-os/(.*)",             "destination": "/fleet-os-dist/$1" },
    { "source": "/(.*)",                      "destination": "/pwa-dist/$1" }
  ],
  "headers": [
    {
      "source": "/pwa-dist/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
