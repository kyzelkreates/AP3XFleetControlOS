{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": null,
  "builds": [
    { "src": "api/fleets.js",  "use": "@vercel/node" },
    { "src": "api/deploy.js",  "use": "@vercel/node" },
    { "src": "api/devices.js", "use": "@vercel/node" },
    { "src": "api/drivers.js", "use": "@vercel/node" },
    { "src": "api/hazards.js", "use": "@vercel/node" },
    { "src": "api/safety.js",  "use": "@vercel/node" },
    { "src": "api/tacho.js",   "use": "@vercel/node" },
    { "src": "api/nav.js",     "use": "@vercel/node" },
    { "src": "api/obs.js",     "use": "@vercel/node" },
    { "src": "ui/**/*.html",   "use": "@vercel/static" },
    { "src": "pwa/**/*",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/fleets",             "dest": "/api/fleets.js"  },
    { "src": "/api/createFleet",        "dest": "/api/fleets.js"  },
    { "src": "/api/updateFleet",        "dest": "/api/fleets.js"  },

    { "src": "/api/deploy",             "dest": "/api/deploy.js"  },
    { "src": "/api/deployFleet",        "dest": "/api/deploy.js"  },
    { "src": "/api/deployment/(.*)",    "dest": "/api/deploy.js"  },

    { "src": "/api/devices",            "dest": "/api/devices.js" },
    { "src": "/api/device/(.*)",        "dest": "/api/devices.js" },

    { "src": "/api/drivers",            "dest": "/api/drivers.js" },
    { "src": "/api/driver/(.*)",        "dest": "/api/drivers.js" },

    { "src": "/api/hazards",            "dest": "/api/hazards.js" },
    { "src": "/api/hazard/(.*)",        "dest": "/api/hazards.js" },

    { "src": "/api/safety",             "dest": "/api/safety.js"  },
    { "src": "/api/safetyCheck",        "dest": "/api/safety.js"  },

    { "src": "/api/tacho",              "dest": "/api/tacho.js"   },
    { "src": "/api/tacho/(.*)",         "dest": "/api/tacho.js"   },

    { "src": "/api/nav",                "dest": "/api/nav.js"     },
    { "src": "/api/nav/(.*)",           "dest": "/api/nav.js"     },

    { "src": "/api/obs",                "dest": "/api/obs.js"     },
    { "src": "/api/obs/(.*)",           "dest": "/api/obs.js"     },

    { "src": "/ui/(.*)",                "dest": "/ui/$1"          },
    { "src": "/pwa/(.*)",               "dest": "/pwa/$1"         },
    { "src": "/",                       "dest": "/ui/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/pwa/(.*)",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control",          "value": "no-cache" }
      ]
    },
    {
      "source": "/pwa/sw.js",
      "headers": [
        { "key": "Content-Type",  "value": "application/javascript" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
